rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /stockLedgers/{ledgerId} {
      function signedIn() {
        return request.auth != null;
      }

      function hasVerifiedEmail() {
        return signedIn()
          && request.auth.token.email != null
          && request.auth.token.email_verified == true;
      }

      function ownsExistingLedger() {
        return signedIn()
          && (resource.data.ownerUid == request.auth.uid
            || (hasVerifiedEmail()
              && resource.data.ownerEmail == request.auth.token.email));
      }

      function ownsNewLedger() {
        return signedIn()
          && request.resource.data.ownerUid == request.auth.uid
          && hasVerifiedEmail()
          && request.resource.data.ownerEmail == request.auth.token.email;
      }

      allow read: if ownsExistingLedger();
      allow create: if ownsNewLedger();
      allow update: if ownsExistingLedger() && ownsNewLedger();
        
      match /chunks/{chunkId} {
        function parentBefore() {
          return get(/databases/$(database)/documents/stockLedgers/$(ledgerId));
        }

        function parentAfter() {
          return getAfter(/databases/$(database)/documents/stockLedgers/$(ledgerId));
        }

        function ownsParentBefore() {
          return signedIn()
            && (parentBefore().data.ownerUid == request.auth.uid
              || (hasVerifiedEmail()
                && parentBefore().data.ownerEmail == request.auth.token.email));
        }

        function ownsParentAfter() {
          return signedIn()
            && parentAfter().data.ownerUid == request.auth.uid
            && hasVerifiedEmail()
            && parentAfter().data.ownerEmail == request.auth.token.email;
        }

        allow read: if signedIn()
          && (resource.data.ownerUid == request.auth.uid || ownsParentBefore());
        allow create, update: if ownsParentAfter()
          && request.resource.data.ownerUid == request.auth.uid;
        allow delete: if ownsParentAfter();
      }
    }
  }
}
